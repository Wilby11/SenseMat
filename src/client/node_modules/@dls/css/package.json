{
  "name": "@dls/css",
  "version": "13.0.4",
  "description": "Lightweight CSS library of the Philips Design Language System (DLS) to include in any web project",
  "keywords": [
    "Design",
    "DLS",
    "dDLS",
    "Styles",
    "CSS",
    "Toolkit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/philips-internal/dls-css"
  },
  "author": "Henri Schröter",
  "contributors": [
    {
      "name": "Henri Schröter",
      "email": "henri.schroter@philips.com",
      "url": "https://github.com/henrilouis"
    },
    {
      "name": "Tijmen van Gurp",
      "email": "tijmen.van.gurp@philips.com",
      "url": "https://github.com/tijmenvangurp"
    },
    {
      "name": "Bart van Lieshout",
      "email": "bart.van.lieshout@philips.com",
      "url": "https://github.com/Bartcha"
    }
  ],
  "main": "index.js",
  "files": [
    "colors",
    "components",
    "elements",
    "fonts",
    "images",
    "unofficial",
    "dls.css",
    "prefix-dls.css",
    "favicon.svg"
  ],
  "scripts": {
    "backstop": "node scripts/backstop.js",
    "build": "npm run generate-bundle && npm run generate-website && npm run webpack:bundle",
    "bundle": "npm run generate-bundle && npm run webpack:bundle && npm run zip",
    "css:add-fallback": "node -r esm scripts/addFallbackToToken.js",
    "css:approve": "backstop approve",
    "css:remove-fallback": "node -r esm scripts/removeFallbackFromToken.js",
    "css:test": "npm run css:add-fallback && npm run generate-website && webpack --config webpack/webpack.website.prod.js && npm run backstop && npm run css:remove-fallback && npm run prettier-format",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "generate-bundle": "node -r esm scripts/generateBundle.js",
    "generate-website": "node -r esm scripts/generateWebsite.js && npm run webpack:website",
    "generate:watch": "node -r esm scripts/watcher.js",
    "new-component": "sh scripts/new-component.sh",
    "prepublishOnly": "npm run bundle && cp -r ./bundle/ .",
    "prettier-format": "prettier --config .prettierrc.yml '**/*.{json,js,jsx,ts,tsx,css,scss,less,overrides,md}' --write",
    "postpublish": "git clean -fd",
    "release": "dotenv release-it",
    "release:dry": "dotenv release-it --dry-run",
    "sanitize": "npm run prettier-format && npm run stylelint",
    "start": "concurrently \"webpack-dev-server --config webpack/webpack.website.dev.js\" \"npm:generate:watch\" ",
    "stylelint": "stylelint \"**/*.scss\" --syntax scss --fix",
    "webpack:bundle": "webpack --config webpack/webpack.bundle.js",
    "webpack:website": "webpack --config webpack/webpack.website.prod.js",
    "zip": "bestzip bundle.zip bundle"
  },
  "devDependencies": {
    "@babel/core": "^7.12.9",
    "@babel/preset-env": "^7.12.7",
    "@babel/preset-react": "^7.12.7",
    "@dls/design-token-transpiler": "^2.3.4",
    "babel-loader": "^8.2.1",
    "backstopjs": "^5.0.6",
    "beautify-html-webpack-plugin": "^1.0.3",
    "bestzip": "^2.2.0",
    "change-case": "^4.1.1",
    "chokidar-cli": "^2.1.0",
    "clean-webpack-plugin": "^3.0.0",
    "concurrently": "^5.3.0",
    "copy-webpack-plugin": "^6.3.1",
    "css-loader": "^5.0.1",
    "css-minimizer-webpack-plugin": "^1.1.5",
    "dotenv-cli": "^4.0.0",
    "esm": "^3.2.25",
    "favicons-webpack-plugin": "^4.2.0",
    "file-loader": "^6.2.0",
    "fs-extra": "^9.0.1",
    "gh-pages": "^3.1.0",
    "html-loader": "^1.3.2",
    "html-webpack-plugin": "^4.5.0",
    "js-beautify": "^1.13.0",
    "mini-css-extract-plugin": "^1.6.2",
    "postcss": "^8.1.10",
    "postcss-loader": "^4.0.4",
    "postcss-preset-env": "^6.7.0",
    "prettier-stylelint": "^0.4.2",
    "puppeteer": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^18.0.1",
    "react-router-dom": "^6.3.0",
    "release-it": "^14.11.8",
    "remove-files-webpack-plugin": "^1.4.4",
    "resolve-url-loader": "^3.1.2",
    "sass": "^1.52.3",
    "sass-loader": "^10.1.0",
    "stylelint": "^13.8.0",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-sass-guidelines": "^7.1.0",
    "stylelint-config-standard": "^20.0.0",
    "stylelint-no-px": "^1.0.1",
    "stylelint-order": "^4.1.0",
    "stylelint-processor-html": "^1.0.0",
    "stylelint-scss": "^3.18.0",
    "url-loader": "^4.1.1",
    "webpack": "^4.44.2",
    "webpack-cli": "^3.2.1",
    "webpack-dev-server": "^3.1.14",
    "webpack-fix-style-only-entries": "^0.6.0",
    "webpack-merge": "^5.4.0",
    "yaml": "^1.10.0"
  },
  "publishConfig": {
    "registry": "https://artifactory-ehv.ta.philips.com/artifactory/api/npm/dl-innersource-npm/"
  },
  "dependencies": {
    "react-syntax-highlighter": "^15.5.0"
  }
}
